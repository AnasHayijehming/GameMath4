  npc_city_merchant: 'NPC portrait: friendly fraction merchant with colorful accessories.',
  npc_city_engineer: 'NPC portrait: inventive decimal engineer with goggles and tools.',
  npc_castle_geomancer: 'NPC portrait: calm geometry mage with angular motifs and staff.',
  npc_castle_boss: 'NPC portrait: dramatic but kid-safe shadow math king boss character.',

  item_icon_hint_scroll: 'Item icon: magical hint scroll with sparkling rune seal.',
  item_icon_time_boost: 'Item icon: hourglass power-up with bright magical glow.',
  item_icon_coin_magnet: 'Item icon: coin magnet charm in playful fantasy style.',
  item_icon_armor: 'Item icon: child-friendly fantasy armor chestplate with gem accent.'
};

main().catch((err) => {
  console.error(err.stack || err.message || err);
  process.exit(1);
});

async function main() {
  const args = parseArgs(process.argv.slice(2));
  const command = args._[0] || 'scan';

  if (args.help || args.h) {
    printHelp();
    return;
  }

  if (command === 'scan') {
    await scanAssets();
    return;
  }

  if (command === 'edit') {
    await improveOne(args, 'edit');
    return;
  }

  if (command === 'generate') {
    await improveOne(args, 'generate');
    return;
  }

  if (command === 'missing-variations') {
    await generateMissingVariations(args);
    return;
  }

  throw new Error(`Unknown command "${command}". Run "node tools/improve-assets --help".`);
}

async function scanAssets() {
  const files = await listFiles(ASSETS_DIR);
  const manifest = await readManifest();
  const imageFiles = files.filter((file) => isImage(file));
  const byExtension = countBy(imageFiles, (file) => path.extname(file).toLowerCase() || '[none]');
  const byFolder = countBy(imageFiles, (file) => {
    const rel = path.relative(ASSETS_DIR, path.dirname(file));
    return rel || '.';
  });
  const byManifestType = countBy(Object.keys(manifest.assets || {}), inferAssetType);

  console.log('Asset scan');
  console.log(`- Manifest assets: ${Object.keys(manifest.assets || {}).length}`);
  console.log(`- Image files present: ${imageFiles.length}`);
  console.log(`- Non-image files present: ${files.length - imageFiles.length}`);
  console.log('- Manifest asset types:');
  printCounts(byManifestType);
  console.log('- Image types:');
  printCounts(byExtension);
  console.log('- Image folders:');
  printCounts(byFolder);

  const missing = Object.entries(manifest.assets || {})
    .filter(([, relPath]) => !files.includes(path.join(ROOT, relPath)))
    .map(([key, relPath]) => `${key} -> ${relPath}`);

  if (missing.length) {
    console.log('- Missing manifest image outputs:');
    missing.forEach((line) => console.log(`  ${line}`));
  } else {
    console.log('- Missing manifest image outputs: none');
  }
}

async function improveOne(args, mode) {
  const manifest = await readManifest();
  const key = args.key || args.asset || args['asset-key'] || null;
  const input = args.input || (key && manifest.assets && manifest.assets[key] ? path.join(ROOT, manifest.assets[key]) : null);
  const inputExists = input ? await exists(input) : false;
  const sourceInfo = inputExists ? await inspectSource(input) : null;
  const effectiveMode = sourceInfo ? 'edit' : mode;

  if (mode === 'edit' && !input) {
    throw new Error('edit requires --input or --key pointing to an existing manifest asset.');
  }

  if (mode === 'edit' && !inputExists) {
    throw new Error(`Input image not found: ${input}`);
  }

  const formats = parseFormats(args.format || args.formats || 'png');
  const count = positiveInt(args.count || 1, 'count');
  const prompt = buildPrompt({
    key,
    mode: effectiveMode,
    userPrompt: args.prompt,
    sourceInfo
  });

  for (let index = 0; index < count; index += 1) {
    for (const format of formats) {
      const plan = await buildOutputPlan({ key, mode: effectiveMode, format, index, prompt, sourceInfo, args });
      await runPlan(plan, args);
    }
  }
}

async function generateMissingVariations(args) {
  const manifest = await readManifest();
  const entries = Object.entries(manifest.assets || {});
  const missing = [];

  for (const [key, relPath] of entries) {
    const absPath = path.join(ROOT, relPath);
    if (!(await exists(absPath))) missing.push([key, relPath]);
  }

  if (!missing.length) {
    console.log('No missing manifest assets found.');
    return;
  }

  const formats = parseFormats(args.format || args.formats || 'png');

  for (const [key, relPath] of missing) {
    const prompt = buildPrompt({
      key,
      mode: 'missing-variations',
      userPrompt: args.prompt,
      sourceInfo: null
    });

    for (const format of formats) {
      const plan = await buildOutputPlan({
        key,
        mode: 'missing-variations',
        format,
        index: 0,
        prompt,
        sourceInfo: null,
        args: Object.assign({}, args, { missingOriginal: relPath })
      });
      await runPlan(plan, args);
    }
  }
}

async function runPlan(plan, args) {
  if (args['dry-run'] || args.dryRun) {
    console.log(`[dry-run] ${plan.mode} ${plan.key || '(custom)'} -> ${path.relative(ROOT, plan.outputPath)}`);
    console.log(`[dry-run] endpoint: ${plan.endpoint}`);
    console.log(`[dry-run] size: ${plan.request.size}; format: ${plan.request.output_format}`);
    console.log(`[dry-run] prompt: ${plan.prompt}`);
    return;
  }

  const apiKey = process.env.OPENAI_API_KEY;
  if (!apiKey) throw new Error('OPENAI_API_KEY is required unless --dry-run is used.');

  await fs.mkdir(path.dirname(plan.outputPath), { recursive: true });
  const backup = plan.sourceInfo ? await backupSourceAsset(plan.sourceInfo) : null;
  if (backup) {
    plan.metadata.sourceBackup = backup;
  }
  const base64 = plan.mode === 'edit'
    ? await callEditApi(apiKey, plan)
    : await callGenerateApi(apiKey, plan);

  await fs.writeFile(plan.outputPath, Buffer.from(base64, 'base64'), { flag: 'wx' });
  await fs.writeFile(plan.metadataPath, `${JSON.stringify(plan.metadata, null, 2)}\n`, { flag: 'wx' });
  console.log(`Wrote ${path.relative(ROOT, plan.outputPath)}`);
  console.log(`Wrote ${path.relative(ROOT, plan.metadataPath)}`);
}

async function callGenerateApi(apiKey, plan) {
  const response = await fetch('https://api.openai.com/v1/images/generations', {
    method: 'POST',
    headers: {
      Authorization: `Bearer ${apiKey}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify(plan.request)
  });

  return readImageResponse(response, plan.key);
}

async function callEditApi(apiKey, plan) {
  const form = new FormData();
  const image = await fs.readFile(plan.sourceInfo.absolutePath);
  form.append('image', new Blob([image], { type: mimeType(plan.sourceInfo.absolutePath) }), path.basename(plan.sourceInfo.absolutePath));

  for (const [key, value] of Object.entries(plan.request)) {
    if (value !== undefined && value !== null) form.append(key, String(value));
  }

  const response = await fetch('https://api.openai.com/v1/images/edits', {
    method: 'POST',
    headers: { Authorization: `Bearer ${apiKey}` },
    body: form
  });

  return readImageResponse(response, plan.key);
}

async function readImageResponse(response, key) {
  if (!response.ok) {
    const body = await response.text();
    throw new Error(`Image API failed for ${key || 'custom asset'}: ${response.status} ${body}`);
  }

  const json = await response.json();
  const base64 = json && json.data && json.data[0] && json.data[0].b64_json;
  if (!base64) throw new Error(`No image payload returned for ${key || 'custom asset'}`);
  return base64;
}

async function buildOutputPlan({ key, mode, format, index, prompt, sourceInfo, args }) {
  const outputFormat = normalizeFormat(format);
  const safeKey = slug(key || args.name || 'asset');
  const size = args.size || pickSize(key, sourceInfo);
  const transparent = pickTransparency(args, sourceInfo);
  const timestamp = new Date().toISOString().replace(/[:.]/g, '-');
  const proposedBaseName = `${safeKey}-${mode}-${timestamp}-${index + 1}`;
  const baseName = args['dry-run'] || args.dryRun
    ? proposedBaseName
    : await nextAvailableBaseName(proposedBaseName);
  const outputPath = path.join(OUT_DIR, `${baseName}.${outputFormat}`);
  const metadataPath = path.join(OUT_DIR, `${baseName}.json`);
  const request = {
    model: MODEL,
    prompt,
    size,
    output_format: outputFormat
  };

  if (transparent) request.background = 'transparent';

  const metadata = {
    generatedAt: new Date().toISOString(),
    model: MODEL,
    mode,
    key: key || null,
    prompt,
    output: path.relative(ROOT, outputPath).replace(/\\/g, '/'),
    format: outputFormat,
    size,
    transparentBackgroundRequested: Boolean(transparent),
    source: sourceInfo ? redactSourceInfo(sourceInfo) : null,
    sourceBackup: null,
    missingOriginal: args.missingOriginal || null,
    preservedConstraints: {
      artStyle: true,
      colorPalette: true,
      cameraAngle: true,
      spriteSize: true,
      transparentBackground: Boolean(sourceInfo && sourceInfo.hasTransparency)
    }
  };

  return {
    mode: mode === 'edit' ? 'edit' : 'generate',
    key,
    prompt,
    endpoint: mode === 'edit' ? '/v1/images/edits' : '/v1/images/generations',
    request,
    outputPath,
    metadataPath,
    metadata,
    sourceInfo
  };
}

async function backupSourceAsset(sourceInfo) {
  await fs.mkdir(BACKUP_DIR, { recursive: true });
  const sourceBase = path.basename(sourceInfo.absolutePath, path.extname(sourceInfo.absolutePath));
  const backupBase = `${slug(sourceBase)}-${sourceInfo.sha256.slice(0, 12)}${sourceInfo.extension}`;
  const backupPath = path.join(BACKUP_DIR, backupBase);

  if (!(await exists(backupPath))) {
    await fs.copyFile(sourceInfo.absolutePath, backupPath, fs.constants.COPYFILE_EXCL);
  }

  return {
    path: path.relative(ROOT, backupPath).replace(/\\/g, '/'),
    sha256: sourceInfo.sha256
  };
}

function buildPrompt({ key, mode, userPrompt, sourceInfo }) {
  const base = userPrompt || PROMPTS[key] || inferPromptFromKey(key);
  const sourceDetails = sourceInfo
    ? `The provided source image is ${sourceInfo.width || 'unknown'}x${sourceInfo.height || 'unknown'} pixels${sourceInfo.hasTransparency ? ' with transparency' : ''}. Keep the same canvas proportions, camera angle, and transparent background behavior.`
    : 'Create a replacement compatible with the manifest asset slot.';
  return `${base} ${sourceDetails} Workflow: ${mode}. ${STYLE_CONSTRAINTS}`;
}

async function inspectSource(input) {
  const absolutePath = path.resolve(ROOT, input);
  const buffer = await fs.readFile(absolutePath);
  const png = inspectPng(buffer);
  const hash = crypto.createHash('sha256').update(buffer).digest('hex');
  return {
    absolutePath,
    relativePath: path.relative(ROOT, absolutePath).replace(/\\/g, '/'),
    bytes: buffer.length,
    sha256: hash,
    extension: path.extname(absolutePath).toLowerCase(),
    width: png ? png.width : null,
    height: png ? png.height : null,
    hasTransparency: png ? png.hasTransparency : null
  };
}

function inspectPng(buffer) {
  if (buffer.length < 33) return null;
  if (buffer.readUInt32BE(0) !== 0x89504e47 || buffer.readUInt32BE(4) !== 0x0d0a1a0a) return null;

  const width = buffer.readUInt32BE(16);
  const height = buffer.readUInt32BE(20);
  const colorType = buffer[25];
  let hasTransparency = colorType === 4 || colorType === 6;
  let offset = 8;

  while (offset + 12 <= buffer.length) {
    const length = buffer.readUInt32BE(offset);
    const type = buffer.toString('ascii', offset + 4, offset + 8);
    if (type === 'tRNS') hasTransparency = true;
    offset += 12 + length;
  }

  return { width, height, hasTransparency };
}

async function readManifest() {
  const raw = await fs.readFile(MANIFEST_PATH, 'utf8');
  return JSON.parse(raw);
}

async function listFiles(dir) {
  const results = [];
  if (!(await exists(dir))) return results;
  const entries = await fs.readdir(dir, { withFileTypes: true });

  for (const entry of entries) {
    const fullPath = path.join(dir, entry.name);
    if (entry.isDirectory()) {
      results.push(...await listFiles(fullPath));
    } else if (entry.isFile()) {
      results.push(fullPath);
    }
  }

  return results;
}

async function nextAvailableBaseName(baseName) {
  await fs.mkdir(OUT_DIR, { recursive: true });
  let suffix = 0;
  let candidate = baseName;

  while (
    await exists(path.join(OUT_DIR, `${candidate}.png`)) ||
    await exists(path.join(OUT_DIR, `${candidate}.webp`)) ||
    await exists(path.join(OUT_DIR, `${candidate}.json`))
  ) {
    suffix += 1;
    candidate = `${baseName}-${suffix}`;
  }

  return candidate;
}

async function exists(filePath) {
  try {
    await fs.access(filePath);
    return true;
  } catch {
    return false;
  }
}

function parseArgs(argv) {
  const args = { _: [] };
  for (let index = 0; index < argv.length; index += 1) {
    const token = argv[index];
    if (!token.startsWith('--')) {
      args._.push(token);
      continue;
    }

    const eqIndex = token.indexOf('=');
    if (eqIndex !== -1) {
      args[token.slice(2, eqIndex)] = token.slice(eqIndex + 1);
      continue;
    }

    const key = token.slice(2);
    const next = argv[index + 1];
    if (!next || next.startsWith('--')) {
      args[key] = true;
    } else {
      args[key] = next;
      index += 1;
    }
  }
  return args;
}

function parseFormats(value) {
  const formats = String(value).split(',').map((format) => normalizeFormat(format.trim()));
  if (formats.includes('both')) return ['png', 'webp'];
  return [...new Set(formats)];
}

function normalizeFormat(format) {
  const normalized = String(format || 'png').toLowerCase();
  if (normalized !== 'png' && normalized !== 'webp' && normalized !== 'both') {
    throw new Error(`Unsupported format "${format}". Use png, webp, or both.`);
  }
  return normalized;
}

function pickSize(key, sourceInfo) {
  if (sourceInfo && sourceInfo.width && sourceInfo.height) {
    if (sourceInfo.width === 1536 && sourceInfo.height === 1024) return '1536x1024';
    if (sourceInfo.width === sourceInfo.height) return '1024x1024';
  }
  if (key && key.includes('bg')) return '1536x1024';
  return '1024x1024';
}

function pickTransparency(args, sourceInfo) {
  const value = args.transparent || args.background;
  if (value === 'true' || value === true || value === 'transparent') return true;
  if (value === 'false' || value === 'opaque') return false;
  return Boolean(sourceInfo && sourceInfo.hasTransparency);
}

function inferPromptFromKey(key) {
  if (!key) return 'Game asset replacement for a 2D educational fantasy math adventure game.';
  return `Game asset replacement for manifest key "${key}", interpreted from the key name.`;
}

function inferAssetType(key) {
  if (key === 'title_bg') return 'title/background';
  if (key.startsWith('ui_')) return 'ui/texture';
  if (key.includes('_tile_')) return 'map/tile';
  if (key.startsWith('zone_') && key.endsWith('_bg')) return 'zone/background';
  if (key.startsWith('npc_')) return 'npc/portrait';
  if (key.startsWith('item_icon_')) return 'item/icon';
  return 'other';
}

function isImage(file) {
  return ['.png', '.webp', '.jpg', '.jpeg'].includes(path.extname(file).toLowerCase());
}

function countBy(items, getKey) {
  return items.reduce((counts, item) => {
    const key = getKey(item);
    counts[key] = (counts[key] || 0) + 1;
    return counts;
  }, {});
}

function printCounts(counts) {
  const entries = Object.entries(counts).sort((a, b) => a[0].localeCompare(b[0]));
  if (!entries.length) {
    console.log('  none');
    return;
  }
  entries.forEach(([key, count]) => console.log(`  ${key}: ${count}`));
}

function positiveInt(value, name) {
  const parsed = Number.parseInt(value, 10);
  if (!Number.isFinite(parsed) || parsed < 1) throw new Error(`--${name} must be a positive integer.`);
  return parsed;
}

function slug(value) {
  return String(value).toLowerCase().replace(/[^a-z0-9_-]+/g, '-').replace(/^-+|-+$/g, '') || 'asset';
}

function mimeType(filePath) {
  const ext = path.extname(filePath).toLowerCase();
  if (ext === '.webp') return 'image/webp';
  if (ext === '.jpg' || ext === '.jpeg') return 'image/jpeg';
  return 'image/png';
}

function redactSourceInfo(sourceInfo) {
  return {
    path: sourceInfo.relativePath,
    bytes: sourceInfo.bytes,
    sha256: sourceInfo.sha256,
    extension: sourceInfo.extension,
    width: sourceInfo.width,
    height: sourceInfo.height,
    hasTransparency: sourceInfo.hasTransparency
  };
}

function printHelp() {
  console.log(`Usage:
  node tools/improve-assets scan
  node tools/improve-assets edit --key title_bg --prompt "make it crisper" --format both
  node tools/improve-assets generate --key npc_forest_teacher --format png
  node tools/improve-assets missing-variations --format webp --dry-run

Options:
  --key, --asset-key       Manifest asset key.
  --input                 Existing image to edit. If omitted, --key uses the manifest path.
  --prompt                Additional or replacement prompt.
  --format                png, webp, or both. Default: png.
  --count                 Number of alternatives per format. Default: 1.
  --size                  OpenAI image size, for example 1024x1024 or 1536x1024.
  --transparent           true/false. Defaults to source PNG transparency when known.
  --dry-run               Print planned API calls without writing images or requiring OPENAI_API_KEY.
`);
}
